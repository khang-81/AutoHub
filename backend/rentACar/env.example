# Sao chép thành .env trên server hoặc export từng biến (Spring Boot đọc biến môi trường hệ thống).
# Chạy backend: SPRING_PROFILES_ACTIVE=prod
# Docker: dùng docker-compose.env.example ở thư mục gốc repo (copy thành .env cho docker compose).

# --- Bắt buộc (prod) ---
SPRING_DATASOURCE_URL=jdbc:sqlserver://HOST:1433;databaseName=autohub;encrypt=true;trustServerCertificate=true
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# JWT — Base64, decode ra ≥ 32 byte (HS256)
JWT_KEY=

# CORS — danh sách origin, phân cách bằng dấu phẩy (không có path)
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

# --- Tuỳ chọn ---
# JWT_EXPIRATION=86400000
# MAIL_USERNAME=
# MAIL_PASSWORD=
# GEMINI_API_KEY=
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
# APP_UPLOAD_ROOT=/var/data/rentacar/uploads
# PORT=8081
# JPA_DDL_AUTO=validate
# Lần đầu tạo schema: JPA_DDL_AUTO=update
