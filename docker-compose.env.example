# Sao chép thành file .env cùng thư mục với docker-compose.yml
# docker compose tự đọc .env

# Mật khẩu SA — BẮT BUỘC đủ mạnh (image Linux): ≥8 ký tự + ít nhất 3/4 nhóm A-Z, a-z, 0-9, ký tự đặc biệt.
# Không dùng: 12345678, admin, sa123 — log sẽ báo "Password validation failed" và db thoát mã 255.
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# JWT (Base64, giống jwt.key khi dev)
JWT_KEY=QXV0b0h1YkBSZW50QUNhciNTZWNyZXRLZXkhMjAyNCQ=

# Origin trình duyệt (CORS) — phải khớp URL bạn mở (Docker web mặc định cổng 3000, xem WEB_PORT)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Chỉ dùng khi chạy frontend bằng npm run dev (frontend/.env). Docker Compose build service web luôn dùng base URL rỗng + Nginx proxy /api.
# VITE_API_URL=http://localhost:8081

# Tuỳ chọn
# API_PORT=8081
# WEB_PORT=3000
# MSSQL_PORT=1433
# JPA_DDL_AUTO=validate
# Đổi thành update nếu cần Hibernate tự sửa schema (không khuyến nghị khi đã dùng script SQL đầy đủ)
