# Sao chép thành file .env cùng thư mục với docker-compose.yml
# docker compose tự đọc .env
#
# Dữ liệu demo (demo.admin@example.com, …): chỉ khi chạy API local — mvn spring-boot:run -Dspring-boot.run.profiles=demo
# Không đặt SPRING_PROFILES_ACTIVE=demo trong Compose (API đang dùng prod).

# Mật khẩu SA — SQL Server yêu cầu độ phức tạp (chữ hoa, thường, số, ký tự đặc biệt, ≥8 ký tự)
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# JWT (Base64, giống jwt.key khi dev)
JWT_KEY=QXV0b0h1YkBSZW50QUNhciNTZWNyZXRLZXkhMjAyNCQ=

# Origin trình duyệt (CORS) — phải khớp URL bạn mở giao diện (vd: Docker Nginx mặc định cổng 8080)
APP_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173

# URL API mà frontend gọi (build-time cho Vite). Trình duyệt từ máy host: thường là localhost + cổng API
VITE_API_URL=http://localhost:8081

# Tuỳ chọn
# API_PORT=8081
# WEB_PORT=8080
# MSSQL_PORT=1433
# JPA_DDL_AUTO=update
